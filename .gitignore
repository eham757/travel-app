# ---------------------------------------------
# Root .gitignore for travel-app (Angular + .NET)
# ---------------------------------------------

# OS files
.DS_Store
Thumbs.db

# Editor/IDE files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*
.idea/
*.sublime-workspace

# ---------------------------------------------
# Frontend (Angular)
# ---------------------------------------------
/fe/node_modules/
/fe/dist/
/fe/.angular/cache/
/fe/coverage/
/fe/tmp/
/fe/out-tsc/
/fe/bazel-out/

# Frontend logs and temp artifacts
/fe/npm-debug.log*
/fe/yarn-error.log*
/fe/pnpm-debug.log*
/fe/testem.log
/fe/connect.lock
/fe/libpeerconnection.log

# ---------------------------------------------
# Backend (.NET)
# ---------------------------------------------
/be/**/bin/
/be/**/obj/
/be/.vs/

# User-specific and tooling files
/be/**/*.user
/be/**/*.suo
/be/**/*.userosscache
/be/**/*.sln.docstates

# Rider/ReSharper
/be/**/_ReSharper*/
/be/**/*.DotSettings.user

# .NET test and coverage artifacts
/be/**/TestResults/
/be/**/coverage/
/be/**/coverage.*

# NuGet/package cache artifacts (if generated in repo)
/be/**/packages/

# Logs
*.log
